run = "npm start"
entrypoint = "api/server.js"

[nix]
channel = "stable-23_11"

[env]
NODE_ENV = "production"

[packager]
language = "nodejs"

  [packager.features]
  packageSearch = true
  guessImports = true

[languages]
  [languages.javascript]
  pattern = "**/*.{js,jsx}"
  [languages.javascript.languageServer]
  start = "node --inspect=0.0.0.0:9229"

[deployment]
run = ["sh", "-c", "npm start"]
deploymentTarget = "cloudrun"
