# ── Minwei API — Environment Variables ──────────────────────────
# Copy this to .env and fill in real values
# NEVER commit .env to git

# Server
PORT=3463
NODE_ENV=production

# Neon Database (use your existing Neon connection string)
DATABASE_URL=postgres://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Stripe
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxx

# WeChat Pay (via Stripe — enable in Stripe Dashboard → Payment Methods → WeChat Pay)
# No extra keys needed — uses same Stripe keys above
WECHAT_PAY_ENABLED=true

# SMS / OTP (Twilio — optional, mock used if not set)
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# Set to "mock" to skip real SMS (logs OTP to console instead)
SMS_MODE=mock

# CORS — comma-separated allowed origins
CORS_ORIGINS=https://repoone822.github.io,http://localhost:8080

# Admin
ADMIN_SECRET=your_admin_secret_for_setup

# Replit-specific
# PORT is set automatically by Replit — do not set manually
# CORS_ORIGINS: add your GitHub Pages URL
# e.g. https://repoone822.github.io,https://your-repl.replit.app
